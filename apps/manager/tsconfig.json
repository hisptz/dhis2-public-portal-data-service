{
    "compilerOptions": {
        "noEmit": true,
        "skipLibCheck": true,
        "allowJs": true,
        "jsx": "react-jsx",
        "esModuleInterop": true,
        "target": "ESNext",
        "module": "esnext",
        "moduleResolution": "bundler",
        "strictNullChecks": true,
        "types": ["cypress", "node"],
        "paths": {
            "@/*": ["./src/*"]
        }
    },
    "include": [
        "src",
        "types",
        "tailwind.config.ts",
        "cypress",
        "cypress.config.ts",
        "viteConfigExtensions.mts"
    ]
}
