{
    "name": "dhis2-public-portal-data-service",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "test": "echo \"Error: no test specified\" && exit 1",
        "clean": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' +",
        "lint": "eslint . --fix",
        "lint:check": "eslint . --no-warn-ignored",
        "format": "prettier . --write",
        "format:check": "prettier --check .",
        "typecheck": "pnpm -r run --if-present typecheck",
        "prepare": "husky"
    },
    "lint-staged": {
        "**/*.{ts,tsx,js,mjs,cjs}": [
            "eslint --fix --no-warn-ignored",
            "prettier --write"
        ],
        "**/*.{json,yaml,yml,md}": [
            "prettier --write"
        ]
    },
    "keywords": [],
    "author": "HISP Tanzania<dev@hisptanzania.org>",
    "license": "BSD-3-Clause",
    "packageManager": "pnpm@10.32.1",
    "devDependencies": {
        "@dhis2/config-prettier": "^0.2.2",
        "@eslint/compat": "^2.0.3",
        "@eslint/js": "^10.0.1",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.4.0",
        "husky": "^9.0.0",
        "lint-staged": "^15.0.0",
        "prettier": "^3.8.1",
        "typescript-eslint": "^8.0.0"
    }
}
