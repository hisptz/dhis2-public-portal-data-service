{
    "name": "data-service",
    "version": "1.0.0",
    "description": "Service to transfer data from source DHIS2 instances to the portal",
    "main": "index.js",
    "private": true,
    "type": "module",
    "license": "MIT",
    "scripts": {
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:studio": "prisma studio",
        "prisma:reset": "prisma migrate reset",
        "dev:worker": "bun run src/rabbit/worker.ts --watch --hot",
        "dev:api": "bun run src/app.ts --watch --hot",
        "start:api": "bun run src/app.ts",
        "start:worker": "bun run src/rabbit/worker.ts",
        "dev": "concurrently --names 'worker,api' -c 'blue,green' 'pnpm  run dev:worker' 'pnpm run dev:api'  ",
        "build": "bun run build.ts",
        "lint:check": "eslint .",
        "format:check": "prettier --check .",
        "check-types": "tsc --noEmit"
    },
    "dependencies": {
        "@dhis2/multi-calendar-dates": "^2.1.0",
        "@hisptz/dhis2-utils": "^2.0.19",
        "@openapi-contrib/json-schema-to-openapi-schema": "^4.3.0",
        "shared": "workspace:*",
        "@prisma/adapter-pg": "^7.3.0",
        "@prisma/client": "^7.3.0",
        "@types/cors": "^2.8.19",
        "@types/qs": "^6.14.0",
        "@types/swagger-ui-express": "^4.1.8",
        "amqplib": "^0.10.8",
        "async": "^3.2.6",
        "axios": "^1.14.0",
        "body-parser": "^2.2.0",
        "cors": "^2.8.5",
        "express": "^5.1.0",
        "express-openapi": "^12.1.3",
        "figlet": "^1.8.0",
        "lodash": "4.17.23",
        "luxon": "^3.6.1",
        "p-limit": "^6.2.0",
        "prisma": "^7.3.0",
        "qs": "^6.14.1",
        "swagger-ui-express": "^5.0.1",
        "uuid": "^11.1.0",
        "winston": "^3.17.0",
        "zod": "^4.3.6",
        "zod-validation-error": "^5.0.0"
    },
    "devDependencies": {
        "@types/amqplib": "^0.10.7",
        "@types/async": "^3.2.24",
        "@types/bun": "^1.2.9",
        "@types/express": "^4.17.25",
        "@types/figlet": "^1.7.0",
        "@types/lodash": "^4.17.16",
        "@types/luxon": "^3.6.2",
        "@types/node": "^22.14.0",
        "@types/p-limit": "^2.2.0",
        "bestzip": "^2.2.1",
        "concurrently": "^9.2.1",
        "dotenv": "^16.5.0",
        "dotenv-cli": "^8.0.0",
        "nodemon": "^3.1.9",
        "tsc-alias": "^1.8.16",
        "tsup": "^8.4.0",
        "tsx": "^4.20.6",
        "typescript": "^5.8.3"
    }
}
